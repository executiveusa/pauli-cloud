{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pauli.cloud/schemas/policy.schema.json",
  "title": "Pauli Cloud Compiled Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "protected_branches",
    "approvals",
    "prompt_hashes",
    "capability_fingerprint",
    "rules"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "agent": { "type": "string", "minLength": 1 },
    "protected_branches": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "approvals": { "type": "object" },
    "prompt_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "capability_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
